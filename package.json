{
  "name": "asimov-hex",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "verify": "npm run test && npm run lint && npm run build && echo 'Verification was successful :)'",
    "stats": "scripts/repo-statistics.sh",
    "create-project-statistics": "tsx scripts/create-project-statistics.ts",
    "re-create-git-timeline": "tsx scripts/re-create-git-timeline.ts",
    "deploy-to-server": "./scripts/deploy-dist-to-server.sh",
    
    "commit-from-file": "git commit -F ./temp/commit-message.txt",
    "commit-update-statistics-and-timeline": "npm run create-project-statistics && npm run re-create-git-timeline && git add ./public/project-statistics && git add ./public/project-history && git commit -m 'automated: update project statistics'"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tweakpane/core": "^2.0.5",
    "@types/node": "^20.10.0",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vite": "^5.0.8",
    "vitest": "^2.0.4"
  },
  "dependencies": {
    "@pangenerator/tweakpane-textarea-plugin": "^2.0.0",
    "pixi.js": "^8.0.0",
    "tweakpane": "^4.0.3"
  }
}
